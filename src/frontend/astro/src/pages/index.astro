---
import Layout from '../layouts/Layout.astro'
import { withBase } from '../lib/links'
---

<Layout title="project_keel — Overview" active="overview">
  <section class="text-center">
    <p class="text-sm font-medium uppercase tracking-widest text-indigo-600">Project template</p>
    <h1 class="mt-3 text-balance text-4xl font-bold tracking-tight sm:text-5xl">
      A skeleton that stays <span class="text-indigo-600">honest</span>.
    </h1>
    <p id="hero-tagline" class="mx-auto mt-4 max-w-2xl text-balance text-lg text-slate-600">…</p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href={withBase('/wiki')} class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700">Browse the wiki</a>
      <a href={withBase('/setup')} class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-white">Use it in your project</a>
    </div>
  </section>

  <section id="stats" class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-6"></section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold">The three load-bearing conventions</h2>
    <ol id="conventions" class="mt-4 space-y-2"></ol>
  </section>

  <section class="mt-12 grid gap-6 sm:grid-cols-2">
    <div>
      <h2 class="text-lg font-semibold">Layers</h2>
      <div id="layers" class="mt-4 space-y-2"></div>
    </div>
    <div>
      <h2 class="text-lg font-semibold">Transports</h2>
      <div id="transports" class="mt-4 space-y-2"></div>
    </div>
  </section>

  <section class="mt-12">
    <div class="flex items-baseline justify-between">
      <h2 class="text-lg font-semibold">Highlights</h2>
      <a href={withBase('/features')} class="text-sm font-medium text-indigo-600 hover:underline">All features →</a>
    </div>
    <div id="features-preview" class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3"></div>
  </section>

  <p id="overview-summary" class="mt-12 border-t border-slate-200 pt-6 text-sm leading-relaxed text-slate-500"></p>

  <script>
    import { getOverview, getFeatures } from '../lib/api'
    import { h, mount, byId, showError } from '../lib/dom'
    import { statCard, featureCard, chip } from '../lib/components'

    async function render(): Promise<void> {
      try {
        const [ov, feats] = await Promise.all([getOverview(), getFeatures()])
        byId('hero-tagline').textContent = ov.tagline
        byId('overview-summary').textContent = ov.summary

        mount(byId('stats'),
          statCard(ov.stats.docs, 'docs'),
          statCard(ov.stats.modules, 'modules'),
          statCard(ov.stats.sections, 'sections'),
          statCard(ov.stats.symbols, 'symbols'),
          statCard(ov.stats.directories, 'dirs'),
          statCard(ov.stats.checks, 'checks'))

        mount(byId('conventions'),
          ...ov.conventions.map((c, i) =>
            h('li', { class: 'flex gap-3 rounded-lg border border-slate-200 bg-white p-4' },
              h('span', { class: 'grid h-6 w-6 shrink-0 place-items-center rounded-full bg-indigo-100 text-xs font-bold text-indigo-700' }, String(i + 1)),
              h('span', { class: 'text-sm text-slate-700' }, c))))

        mount(byId('layers'),
          ...ov.layers.map((l) =>
            h('div', { class: 'rounded-lg border border-slate-200 bg-white p-4' },
              h('div', { class: 'flex items-center gap-2' },
                h('span', { class: 'font-medium capitalize' }, l.name),
                chip(l.language, 'indigo'),
                l.stack ? chip(l.stack, 'green') : null),
              h('div', { class: 'mt-1 font-mono text-xs text-slate-400' }, l.path || '—'))))

        mount(byId('transports'),
          ...ov.transports.map((t) =>
            h('div', { class: 'flex items-center gap-2 rounded-lg border border-slate-200 bg-white p-4' },
              h('span', { class: 'font-medium uppercase' }, t.name),
              t.enabled ? chip('enabled', 'green') : chip('available', 'slate'),
              h('span', { class: 'ml-auto font-mono text-xs text-slate-400' }, t.directory))))

        mount(byId('features-preview'), ...feats.slice(0, 3).map(featureCard))
      } catch (err) {
        showError(byId('stats'), err)
      }
    }
    void render()
  </script>
</Layout>
