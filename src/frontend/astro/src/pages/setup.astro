---
import Layout from '../layouts/Layout.astro'
---

<Layout title="project_keel — Use it in your project" active="setup">
  <header>
    <p class="font-mono text-[11px] font-medium uppercase tracking-[0.22em] text-muted">
      <span class="text-teal">//</span> use it · clone to self-checking
    </p>
    <h1 class="mt-2 text-3xl font-semibold text-ink">Use it in your own project</h1>
    <p class="mt-2 text-ink2">Five steps from clone to a self-checking project.</p>
  </header>

  <ol id="steps" class="mt-8 space-y-4">
    <p class="text-sm text-muted">Loading…</p>
  </ol>

  <script>
    import { getSetup } from '../lib/api'
    import { h, mount, byId, showError } from '../lib/dom'
    import { inlineEl } from '../lib/components'

    async function render(): Promise<void> {
      try {
        const steps = await getSetup()
        mount(byId('steps'),
          ...steps.map((s, i) =>
            h('li', { class: 'flex gap-4 rounded-xl border border-line bg-panel p-5' },
              h('span', { class: 'grid h-8 w-8 shrink-0 place-items-center rounded-lg border border-teal/40 bg-teal/10 font-mono text-sm font-medium text-teal' }, String(i + 1)),
              h('div', { class: 'min-w-0 flex-1' },
                h('h3', { class: 'font-semibold text-ink' }, s.title),
                inlineEl('p', 'mt-1 text-sm text-ink2 [&_code]:rounded [&_code]:bg-panel2 [&_code]:px-1 [&_code]:font-mono', s.body),
                s.command
                  ? h('pre', { class: 'mt-3 overflow-x-auto rounded-lg border border-line bg-panel2 px-4 py-2.5 text-xs' },
                      h('code', { class: 'font-mono text-ink' }, h('span', { class: 'text-teal' }, '$ '), s.command))
                  : null))))
      } catch (err) {
        showError(byId('steps'), err)
      }
    }
    void render()
  </script>
</Layout>
