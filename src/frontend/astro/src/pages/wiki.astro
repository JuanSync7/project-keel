---
import Layout from '../layouts/Layout.astro'
---

<Layout title="project_keel — Wiki" active="wiki" wide={true}>
  <div class="grid gap-8 lg:grid-cols-[20rem_1fr]">
    <aside class="lg:sticky lg:top-20 lg:h-[calc(100vh-7rem)] lg:overflow-y-auto">
      <input
        id="search"
        type="search"
        placeholder="Search docs, modules, sections…"
        class="w-full rounded-lg border border-line bg-panel px-3 py-2 text-sm text-ink outline-none placeholder:text-muted focus:border-teal"
      />
      <p id="tree-hint" class="mt-2 text-xs text-muted">Everything the repo compiles into — docs, code, sections.</p>
      <nav id="tree" class="mt-3 space-y-4">
        <p class="text-sm text-muted">Loading…</p>
      </nav>
    </aside>

    <article id="content" class="min-w-0">
      <p class="text-sm text-muted">Select an entry to begin.</p>
    </article>
  </div>

  <script>
    import { getTree, getNode, search } from '../lib/api'
    import type { NodeDetail } from '../lib/api'
    import { withBase } from '../lib/links'
    import { h, mount, byId, showError } from '../lib/dom'
    import { chip, nodeRefLink, inlineEl } from '../lib/components'
    import { renderMarkdown } from '../lib/md'

    const tree = byId('tree')
    const content = byId('content')
    const searchBox = byId('search') as HTMLInputElement

    async function showNode(id: string, push = true): Promise<void> {
      try {
        const n: NodeDetail = await getNode(id)
        if (push) {
          const url = withBase(`/wiki?id=${encodeURIComponent(id)}`)
          history.pushState({ id }, '', url)
        }
        renderNode(n)
        content.scrollIntoView({ block: 'start', behavior: 'smooth' })
      } catch (err) {
        showError(content, err)
      }
    }

    function renderNode(n: NodeDetail): void {
      mount(content,
        h('div', { class: 'flex flex-wrap items-center gap-2' },
          chip(n.kind, 'teal'),
          n.owner ? chip('owner: ' + n.owner, 'slate') : null,
          h('span', { class: 'font-mono text-xs text-muted' },
            n.path + (n.lineno ? ':' + n.lineno : ''))),
        inlineEl('h1', 'mt-3 text-3xl font-bold tracking-tight [&_code]:font-mono [&_code]:text-2xl', n.title),
        n.summary
          ? inlineEl('p', 'mt-3 text-lg text-ink2 [&_code]:rounded [&_code]:bg-panel2 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-base', n.summary)
          : null,
        n.tags.length
          ? h('div', { class: 'mt-4 flex flex-wrap gap-1.5' }, n.tags.map((t) => chip(t)))
          : null,
        mdBlock(n),
        n.parent ? section('Parent', [n.parent]) : null,
        n.children.length ? section(n.kind === 'module' ? 'Symbols' : 'Sections', n.children) : null,
        n.related.length ? section('Related', n.related) : null,
      )
    }

    function section(label: string, refs: NodeDetail['children']): HTMLElement {
      return h('section', { class: 'mt-8' },
        h('h2', { class: 'text-sm font-semibold uppercase tracking-wide text-muted' }, label),
        h('div', { class: 'mt-2 divide-y divide-line rounded-xl border border-line bg-panel' },
          ...refs.map((r) => nodeRefLink(r, (id) => void showNode(id)))))
    }

    // The node's body, rendered from markdown to sanitized HTML and styled with
    // Tailwind Typography. This is the only place we assign innerHTML — the HTML
    // is produced by renderMarkdown (marked → DOMPurify).
    function mdBlock(n: NodeDetail): HTMLElement | null {
      const md = n.markdown || n.excerpt
      if (!md) return null
      const wrap = h('section', { class: 'mt-6 rounded-xl border border-line bg-panel p-6' })
      const prose = h('div', { class: 'prose max-w-none' })
      prose.innerHTML = renderMarkdown(md)
      // Wide markdown tables must scroll inside their own box, never overflow
      // the column or squash the page.
      prose.querySelectorAll('table').forEach((t) => {
        const scroller = document.createElement('div')
        scroller.className = 'overflow-x-auto'
        t.replaceWith(scroller)
        scroller.appendChild(t)
      })
      wrap.appendChild(prose)
      return wrap
    }

    async function renderTree(): Promise<void> {
      try {
        const groups = await getTree()
        if (!groups.length) {
          mount(tree, h('p', { class: 'text-sm text-muted' },
            'The corpus is empty. Build it: ',
            h('code', { class: 'font-mono text-xs' }, 'make site-data'), '.'))
          return
        }
        mount(tree,
          ...groups.map((g) =>
            h('div', null,
              h('p', { class: 'px-3 text-xs font-semibold uppercase tracking-wide text-muted' },
                g.directory === '.' ? '(root)' : g.directory),
              h('div', { class: 'mt-1' },
                ...g.docs.map((d) => nodeRefLink(d, (id) => void showNode(id)))))))
      } catch (err) {
        showError(tree, err)
      }
    }

    async function runSearch(q: string): Promise<void> {
      if (!q.trim()) { void renderTree(); return }
      try {
        const hits = await search(q, 25)
        mount(tree,
          h('p', { class: 'px-3 text-xs font-semibold uppercase tracking-wide text-muted' },
            `${hits.length} result${hits.length === 1 ? '' : 's'}`),
          ...hits.map((hit) => nodeRefLink(hit.node, (id) => void showNode(id))))
      } catch (err) {
        showError(tree, err)
      }
    }

    let timer: ReturnType<typeof setTimeout> | undefined
    searchBox.addEventListener('input', () => {
      clearTimeout(timer)
      timer = setTimeout(() => void runSearch(searchBox.value), 200)
    })

    window.addEventListener('popstate', () => {
      const id = new URLSearchParams(location.search).get('id')
      if (id) void showNode(id, false)
    })

    // boot: load tree, then open the deep-linked node or the conventions doc.
    void renderTree()
    const initial = new URLSearchParams(location.search).get('id') ?? 'conventions'
    void showNode(initial, false)
  </script>
</Layout>
