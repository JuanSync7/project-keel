---
import Layout from '../layouts/Layout.astro'
import { withBase } from '../lib/links'
---

<Layout title="project_keel — Architecture" active="architecture" wide={true}>
  <header>
    <p class="font-mono text-[11px] font-medium uppercase tracking-[0.22em] text-muted">
      <span class="text-teal">//</span> architecture · one source, two audiences
    </p>
    <h1 class="mt-2 text-3xl font-semibold text-ink">Architecture</h1>
    <p class="mt-2 max-w-2xl text-ink2">
      One source of truth — the repo — projected two ways: a rendered wiki for
      humans and a structured surface for agents. Each layer is thin and depends
      only inward.
    </p>
  </header>

  <section class="mt-10">
    <h2 class="text-lg font-semibold text-ink">One source, two audiences</h2>
    <p class="mt-2 max-w-3xl text-sm text-ink2">
      Docs and code are verified by deterministic checks, compiled into a
      knowledge graph (<code class="rounded border border-line bg-panel2 px-1 font-mono text-[0.8em]">wiki/corpus.json</code>),
      read by a pure domain model, and served over a thin API. The same API
      feeds the human wiki and the agent surface.
    </p>
    <div class="mt-4 overflow-x-auto rounded-xl border border-line bg-[#0e0f12] p-4">
      <div id="diagram-flow" class="flex justify-center">
        <p class="py-8 text-sm text-muted">Rendering diagram…</p>
      </div>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-ink">Layering &amp; dependency rules</h2>
    <p class="mt-2 max-w-3xl text-sm text-ink2">
      Dependencies point one way: <code class="rounded border border-line bg-panel2 px-1 font-mono text-[0.8em]">app → {'{frontend, backend}'} → shared</code>.
      Transports and agents are thin adapters over the domain; providers hide
      behind <code class="rounded border border-line bg-panel2 px-1 font-mono text-[0.8em]">models/</code>.
    </p>
    <div class="mt-4 overflow-x-auto rounded-xl border border-line bg-[#0e0f12] p-4">
      <div id="diagram-layers" class="flex justify-center"></div>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-ink">Model adapters</h2>
    <p class="mt-2 max-w-3xl text-sm text-ink2">
      Providers registered behind <code class="rounded border border-line bg-panel2 px-1 font-mono text-[0.8em]">models/</code>
      and selected by name — swap one for another with no change to the agents
      that call them. Live from <code class="rounded border border-line bg-panel2 px-1 font-mono text-[0.8em]">config/project.json</code>.
    </p>
    <div id="model-adapters" class="mt-4 grid gap-2 sm:grid-cols-3">
      <p class="text-sm text-muted">Loading…</p>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-lg font-semibold text-ink">Principles</h2>
    <ul class="mt-4 grid gap-3 sm:grid-cols-2">
      <li class="rounded-lg border border-line bg-panel p-4 text-sm text-ink2"><strong class="font-medium text-ink">Thin transports.</strong> <code class="font-mono">api/</code> and <code class="font-mono">mcp/</code> validate and call into <code class="font-mono">src/</code> — no domain logic in handlers.</li>
      <li class="rounded-lg border border-line bg-panel p-4 text-sm text-ink2"><strong class="font-medium text-ink">__init__ is the API.</strong> Nothing leaves a package except through <code class="font-mono">__all__</code>; privates stay private.</li>
      <li class="rounded-lg border border-line bg-panel p-4 text-sm text-ink2"><strong class="font-medium text-ink">Deterministic gate.</strong> The checks make the repo well-formed, which is what makes the corpus reproducible.</li>
      <li class="rounded-lg border border-line bg-panel p-4 text-sm text-ink2"><strong class="font-medium text-ink">Live sync.</strong> The frontend fetches at runtime and the API re-reads files on change — no rebuild to reflect an edit.</li>
      <li class="rounded-lg border border-line bg-panel p-4 text-sm text-ink2"><strong class="font-medium text-ink">Swappable runtime.</strong> An agent's control flow is a neutral <code class="font-mono">Plan</code> run by a <code class="font-mono">Runtime</code> — durable &amp; resumable; <code class="font-mono">langgraph</code> is one optional adapter behind <code class="font-mono">runtimes/</code>.</li>
    </ul>
  </section>

  <section class="mt-12">
    <div class="flex items-baseline justify-between">
      <h2 class="text-lg font-semibold text-ink">Features</h2>
      <a href={withBase('/features')} class="font-mono text-[11px] uppercase tracking-wider text-teal hover:underline">All features →</a>
    </div>
    <div id="arch-features" class="mt-4 grid gap-4 sm:grid-cols-2">
      <p class="text-sm text-muted">Loading…</p>
    </div>
  </section>

  <script>
    import mermaid from 'mermaid'
    import { getFeatures, getModels, type ModelAdapter } from '../lib/api'
    import { mount, byId, showError, h } from '../lib/dom'
    import { featureCard } from '../lib/components'

    function modelRow(m: ModelAdapter): HTMLElement {
      return h('div', { class: 'flex items-center justify-between rounded-lg border border-line bg-panel px-4 py-2.5' },
        h('span', { class: 'font-mono text-sm text-ink' }, m.name),
        m.default
          ? h('span', { class: 'rounded-full border border-teal/40 px-2 py-0.5 font-mono text-[10px] uppercase tracking-wide text-teal' }, 'default')
          : h('span', { class: 'font-mono text-[11px] text-muted' }, `${m.directory}/`))
    }

    // Dark "field-guide" mermaid theme — concrete hex (mermaid can't read CSS
    // vars). Diagrams sit on a fixed dark panel in both light/dark site themes.
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: 'strict',
      theme: 'base',
      themeVariables: {
        fontFamily: "'DM Sans', ui-sans-serif, system-ui, sans-serif",
        fontSize: '13px',
        lineColor: '#888d96',
        primaryColor: '#141519',
        primaryBorderColor: '#23252b',
        primaryTextColor: '#ededed',
        clusterBkg: '#0b0c0f',
        clusterBorder: '#23252b',
        edgeLabelBackground: '#141519',
      },
      flowchart: { useMaxWidth: true, htmlLabels: true, curve: 'basis', padding: 14 },
    })

    const FLOW = `flowchart TB
  DOCS["docs + code<br/>*.md · *.py"]:::src
  RULES["AGENT.md per dir<br/>+ frontmatter labels"]:::src
  FACTS["config/project.json<br/>machine-checked facts"]:::src
  CHECKS{{"deterministic checks<br/>structure · corpus · contracts"}}:::gate
  BUILD["build_corpus → link_corpus<br/>(deterministic, model-free)"]:::pipe
  CORPUS[("wiki/corpus.json<br/>nodes · tree · keyword links")]:::data
  DOMAIN["src/backend/showcase<br/>pure read model"]:::be
  REST["api/rest_fastapi<br/>/api/* · thin transport"]:::be
  WEB["src/frontend/astro<br/>rendered wiki (human)"]:::human
  AGENTV["agent front door<br/>llms.txt · /api JSON<br/>corpus.json · query_corpus"]:::agent
  DOCS --> CHECKS
  FACTS --> CHECKS
  DOCS --> BUILD
  BUILD --> CORPUS
  CORPUS --> DOMAIN
  FACTS --> DOMAIN
  DOMAIN --> REST
  REST -->|"renders"| WEB
  REST -->|"JSON"| AGENTV
  CORPUS -.->|"traverse"| AGENTV
  RULES -.->|"rules"| AGENTV
  classDef src fill:#141519,stroke:#3a3f47,color:#ededed;
  classDef gate fill:#211517,stroke:#d98c86,color:#f0d8d4;
  classDef pipe fill:#0e0f12,stroke:#23252b,color:#c2c7d0;
  classDef data fill:#0b2723,stroke:#2fd4bb,color:#d7f5ee;
  classDef be fill:#141519,stroke:#2fd4bb,color:#ededed;
  classDef human fill:#141519,stroke:#6b7280,color:#ededed;
  classDef agent fill:#171327,stroke:#a98ed6,color:#e9e2f5;`

    const LAYERS = `flowchart TB
  APP["app/<br/>composition root"]:::core
  FE["frontend/<br/>UI"]:::core
  BE["backend/<br/>domain + services"]:::core
  SH["shared/<br/>FE↔BE contract"]:::core
  TR["api/ · mcp/<br/>transports (thin)"]:::edge
  AG["agents/<br/>LLM brains"]:::edge
  MO["models/<br/>provider adapters"]:::edge
  RT["runtimes/<br/>control-flow engines<br/>inprocess · langgraph"]:::edge
  APP --> FE
  APP --> BE
  FE --> SH
  BE --> SH
  TR --> BE
  AG --> BE
  AG --> MO
  AG --> RT
  classDef core fill:#0b2723,stroke:#2fd4bb,color:#d7f5ee;
  classDef edge fill:#141519,stroke:#3a3f47,color:#c2c7d0;`

    async function draw(id: string, def: string, targetId: string): Promise<void> {
      const { svg } = await mermaid.render(id, def)
      byId(targetId).innerHTML = svg
    }

    async function init(): Promise<void> {
      try {
        await draw('flow', FLOW, 'diagram-flow')
        await draw('layers', LAYERS, 'diagram-layers')
      } catch (err) {
        showError(byId('diagram-flow'), err)
      }
      try {
        const models = await getModels()
        mount(byId('model-adapters'), ...models.map(modelRow))
      } catch (err) {
        showError(byId('model-adapters'), err)
      }
      try {
        const feats = await getFeatures()
        mount(byId('arch-features'), ...feats.map(featureCard))
      } catch (err) {
        showError(byId('arch-features'), err)
      }
    }
    void init()
  </script>
</Layout>
