---
import Layout from '../layouts/Layout.astro'
import { withBase } from '../lib/links'
---

<Layout title="project_keel — Deterministic checks" active="checks">
  <header>
    <h1 class="text-3xl font-bold tracking-tight">Deterministic checks</h1>
    <p class="mt-2 max-w-2xl text-slate-600">
      The linter for the template itself: same input, same verdict, no model, no network.
      This catalogue is served live from the backend, so it always reflects the checks
      the repo actually ships. Full guide:
      <a class="font-medium text-indigo-600 hover:underline" href={withBase('/wiki?id=docs-guides-deterministic-checks')}>docs/guides/deterministic-checks.md</a>.
    </p>
    <div class="mt-4 rounded-lg border border-slate-200 bg-white p-4 font-mono text-xs text-slate-600">
      <div>$ make check        <span class="text-slate-400"># fast structural gate (runs anywhere)</span></div>
      <div>$ make check-all    <span class="text-slate-400"># the full deterministic suite</span></div>
      <div>$ make verify       <span class="text-slate-400"># check-all + lint + types + tests</span></div>
    </div>
  </header>

  <div id="checks" class="mt-8 grid gap-4">
    <p class="text-sm text-slate-400">Loading…</p>
  </div>

  <script>
    import { getChecks } from '../lib/api'
    import { mount, byId, showError } from '../lib/dom'
    import { checkCard } from '../lib/components'

    async function render(): Promise<void> {
      try {
        const checks = await getChecks()
        mount(byId('checks'), ...checks.map(checkCard))
      } catch (err) {
        showError(byId('checks'), err)
      }
    }
    void render()
  </script>
</Layout>
