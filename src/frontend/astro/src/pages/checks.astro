---
import Layout from '../layouts/Layout.astro'
import { withBase } from '../lib/links'
---

<Layout title="project_keel — Deterministic checks" active="checks">
  <header>
    <p class="font-mono text-[11px] font-medium uppercase tracking-[0.22em] text-muted">
      <span class="text-teal">//</span> checks · same input, same verdict
    </p>
    <h1 class="mt-2 text-3xl font-semibold text-ink">Deterministic checks</h1>
    <p class="mt-2 max-w-2xl text-ink2">
      The linter for the template itself: same input, same verdict, no model, no network.
      This catalogue is served live from the backend, so it always reflects the checks
      the repo actually ships. Full guide:
      <a class="font-medium text-teal hover:underline" href={withBase('/wiki?id=docs-guides-deterministic-checks')}>docs/guides/deterministic-checks.md</a>.
    </p>
    <div class="mt-5 overflow-hidden rounded-lg border border-line bg-panel2">
      <div class="flex items-center gap-1.5 border-b border-line px-3 py-2">
        <span class="h-2.5 w-2.5 rounded-full bg-term-r"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-term-y"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-term-g"></span>
        <span class="ml-2 font-mono text-[10px] uppercase tracking-wider text-muted">make</span>
      </div>
      <div class="space-y-1 px-4 py-3 font-mono text-xs text-ink">
        <div><span class="text-teal">$</span> make check        <span class="text-muted"># fast structural gate (runs anywhere)</span></div>
        <div><span class="text-teal">$</span> make check-all    <span class="text-muted"># the full deterministic suite</span></div>
        <div><span class="text-teal">$</span> make verify       <span class="text-muted"># check-all + lint + types + tests</span></div>
      </div>
    </div>
  </header>

  <div id="checks" class="mt-8 grid gap-4">
    <p class="text-sm text-muted">Loading…</p>
  </div>

  <script>
    import { getChecks } from '../lib/api'
    import { mount, byId, showError } from '../lib/dom'
    import { checkCard } from '../lib/components'

    async function render(): Promise<void> {
      try {
        const checks = await getChecks()
        mount(byId('checks'), ...checks.map(checkCard))
      } catch (err) {
        showError(byId('checks'), err)
      }
    }
    void render()
  </script>
</Layout>
