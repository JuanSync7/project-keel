---
import Layout from '../layouts/Layout.astro'
---

<Layout title="project_keel — Features" active="features">
  <header>
    <p class="font-mono text-[11px] font-medium uppercase tracking-[0.22em] text-muted">
      <span class="text-teal">//</span> features · out of the box
    </p>
    <h1 class="mt-2 text-3xl font-semibold text-ink">Features</h1>
    <p class="mt-2 text-ink2">What you get on day one — rendered live from the backend.</p>
  </header>

  <div id="features" class="mt-8 grid gap-4 sm:grid-cols-2">
    <p class="text-sm text-muted">Loading…</p>
  </div>

  <script>
    import { getFeatures } from '../lib/api'
    import { mount, byId, showError } from '../lib/dom'
    import { featureCard } from '../lib/components'

    async function render(): Promise<void> {
      try {
        const feats = await getFeatures()
        mount(byId('features'), ...feats.map(featureCard))
      } catch (err) {
        showError(byId('features'), err)
      }
    }
    void render()
  </script>
</Layout>
