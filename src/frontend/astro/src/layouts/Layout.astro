---
import '../styles/global.css'
import '@fontsource-variable/inter'
import '@fontsource-variable/dm-sans'
import '@fontsource/dm-mono/400.css'
import '@fontsource/dm-mono/500.css'
import { withBase } from '../lib/links'

interface Props {
  readonly title: string
  readonly active?: string
  readonly wide?: boolean
}

const { title, active = '', wide = false } = Astro.props

// Static (GitHub Pages) build has no backend; keep the footer honest about it.
const isStatic = import.meta.env.PUBLIC_DATA_MODE === 'static'

const nav = [
  { href: '/', label: 'Overview', key: 'overview' },
  { href: '/conventions', label: 'Conventions', key: 'conventions' },
  { href: '/features', label: 'Features', key: 'features' },
  { href: '/architecture', label: 'Architecture', key: 'architecture' },
  { href: '/checks', label: 'Checks', key: 'checks' },
  { href: '/wiki', label: 'Wiki', key: 'wiki' },
  { href: '/setup', label: 'Use it', key: 'setup' },
] as const
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="description" content="project_keel — a polyglot-aware, agent-friendly project skeleton that stays honest." />
    <title>{title}</title>
    <!-- Set the theme before first paint (default: dark) to avoid a flash. -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('theme') === 'light')
            document.documentElement.setAttribute('data-theme', 'light')
        } catch { /* no storage: stay on the dark default */ }
      })()
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <header class="sticky top-0 z-20 border-b border-line bg-bg/80 backdrop-blur">
      <div class="mx-auto flex h-14 max-w-6xl items-center gap-6 px-4 sm:px-6">
        <a href={withBase('/')} class="flex items-center gap-2.5">
          <span class="grid h-6 w-6 place-items-center rounded border border-teal/50 font-mono text-[11px] font-medium text-teal">pk</span>
          <span class="font-mono text-sm font-medium tracking-tight text-ink">project_keel</span>
          <span class="hidden font-mono text-[10px] uppercase tracking-[0.2em] text-muted xl:inline">field guide</span>
        </a>
        <nav class="ml-auto hidden items-center gap-1 lg:flex">
          {nav.map((n) => (
            <a
              href={withBase(n.href)}
              class:list={[
                'rounded-md px-2.5 py-1.5 font-mono text-[11px] uppercase tracking-[0.1em] transition-colors',
                active === n.key
                  ? 'border border-teal/40 text-teal'
                  : 'text-muted hover:text-ink',
              ]}
            >{n.label}</a>
          ))}
        </nav>
        <button
          id="theme-toggle" type="button" title="Toggle light/dark theme" aria-label="Toggle light/dark theme"
          class="grid h-7 w-7 place-items-center rounded-md border border-line text-muted transition-colors hover:text-ink"
        >☾</button>
        <span
          id="sync-badge" title="Backend connection"
          class="flex items-center gap-1.5 rounded-full border border-line px-2.5 py-1 font-mono text-[10px] uppercase tracking-wide text-muted"
        >
          <span id="sync-dot" class="h-1.5 w-1.5 rounded-full bg-muted"></span>
          <span id="sync-text">checking…</span>
        </span>
      </div>
      <nav class="flex gap-1 overflow-x-auto border-t border-line px-4 py-1.5 lg:hidden">
        {nav.map((n) => (
          <a
            href={withBase(n.href)}
            class:list={[
              'whitespace-nowrap rounded-md px-2.5 py-1 font-mono text-[11px] uppercase tracking-[0.1em]',
              active === n.key ? 'border border-teal/40 text-teal' : 'text-muted',
            ]}
          >{n.label}</a>
        ))}
      </nav>
    </header>

    <main class:list={['mx-auto w-full px-4 py-12 sm:px-6', wide ? 'max-w-6xl' : 'max-w-4xl']}>
      <slot />
    </main>

    <footer class="mt-8 border-t border-line">
      <div class="mx-auto flex max-w-6xl flex-col gap-6 px-4 py-8 sm:flex-row sm:items-end sm:justify-between sm:px-6">
        <div class="max-w-xl">
          <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-muted">// data</p>
          {isStatic ? (
            <p class="mt-2 text-sm text-ink2">
              A <strong class="font-medium text-ink">static snapshot</strong> of the project_keel
              showcase — rebuilt from the repo and redeployed on every push.
            </p>
          ) : (
            <p class="mt-2 text-sm text-ink2">
              Rendered <strong class="font-medium text-ink">live</strong> from the project_keel
              backend — edit a doc, rebuild the corpus, reload, and it updates.
            </p>
          )}
          <p class="mt-1 font-mono text-xs text-muted">{isStatic ? 'data:' : 'api:'} <span id="api-base">—</span></p>
        </div>
        <div class="font-mono text-[11px] uppercase tracking-[0.2em] text-muted sm:text-right">
          <p class="text-ink2">project · keel</p>
          <p class="mt-1">rev. 2026 · ed. 02</p>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Theme toggle: dark is default (no attribute); light sets data-theme.
      (function () {
        const btn = document.getElementById('theme-toggle')
        function isLight() { return document.documentElement.getAttribute('data-theme') === 'light' }
        function paint() { if (btn) btn.textContent = isLight() ? '☼' : '☾' }
        paint()
        if (btn) btn.addEventListener('click', function () {
          if (isLight()) { document.documentElement.removeAttribute('data-theme'); try { localStorage.setItem('theme', 'dark') } catch { /* ignore */ } }
          else { document.documentElement.setAttribute('data-theme', 'light'); try { localStorage.setItem('theme', 'light') } catch { /* ignore */ } }
          paint()
        })
      })()
    </script>

    <script>
      import { ping, API_BASE } from '../lib/api'

      const IS_STATIC = import.meta.env.PUBLIC_DATA_MODE === 'static'
      const dot = document.getElementById('sync-dot')
      const text = document.getElementById('sync-text')
      const base = document.getElementById('api-base')

      if (IS_STATIC) {
        if (base) base.textContent = 'static snapshot (no backend)'
        if (dot) dot.className = 'h-1.5 w-1.5 rounded-full bg-teal'
        if (text) text.textContent = 'static'
      } else {
        if (base) base.textContent = API_BASE || 'same origin (/api → backend via dev proxy)'
        const refreshStatus = async (): Promise<void> => {
          const ok = await ping()
          if (dot) dot.className = `h-1.5 w-1.5 rounded-full ${ok ? 'bg-teal' : 'bg-bad'}`
          if (text) text.textContent = ok ? 'live' : 'offline'
        }
        void refreshStatus()
        setInterval(() => void refreshStatus(), 10_000)
      }
    </script>
  </body>
</html>
